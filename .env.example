# === VTEX Headless CMS — fonte de conteúdo ===
# Conta VTEX (tenant). Ex.: cubomedia (por ora), muda no futuro.
VTEX_TENANT=cubomedia
# Workspace VTEX. Produção = master.
VTEX_WORKSPACE=master
# Projeto do Headless CMS (builder na URL /_v/cms/api/{builder}/...). Default do ClientCMS = faststore.
VTEX_CMS_BUILDER=faststore

# === Revalidação on-demand (ISR) ===
# Segredo compartilhado com o webhook de releases do CMS que bate em /api/revalidate?secret=...
CMS_REVALIDATE_SECRET=troque-este-valor
